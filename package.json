{
  "name": "new-project",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "start": "docker compose up --build --remove-orphans",
    "start:detached": "docker compose up --build -d --remove-orphans",
    "dev": "docker compose -f docker-compose.dev.yml up --build --remove-orphans",
    "dev:detached": "docker compose -f docker-compose.dev.yml up --build -d --remove-orphans",
    "prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.production up --build -d --remove-orphans",
    "prod:deploy": "./scripts/prod-deploy.sh",
    "prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.production down --remove-orphans",
    "prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.production logs -f",
    "prod:migrate": "./scripts/prod-migrate.sh",
    "prod:seed": "./scripts/prod-seed.sh",
    "prod:backup": "./scripts/prod-backup.sh",
    "stop": "docker compose down --remove-orphans",
    "stop:dev": "docker compose -f docker-compose.dev.yml down --remove-orphans",
    "logs": "docker compose logs -f",
    "logs:dev": "docker compose -f docker-compose.dev.yml logs -f"
  }
}
